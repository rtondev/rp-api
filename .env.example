# --- Portas ---
# Dev local (docker-compose.yml):
#   API 3001  |  Postgres 5433
# Produção VPS (docker-compose.prod.yml):
#   API 6000 (127.0.0.1)  |  Postgres só rede Docker
#
# Portas já ocupadas na VPS — NÃO usar:
#   1000, 2000, 3307, 5000, 5050, 8080, 25565
PORT=3001
API_PORT=3001
API_HOST_PORT=3001

DATABASE_URL="postgresql://rota:rota123@localhost:5433/rota_potiguar"
JWT_SECRET="change-me-in-production"
POSTGRES_PASSWORD=rota123

# Origens permitidas no CORS (separadas por vírgula).
# Inclua o domínio do frontend na Vercel e previews (*.vercel.app).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://rotapotiguar.com,https://www.rotapotiguar.com,*.vercel.app

# Cloudinary — https://console.cloudinary.com/ (Settings → API Keys)
# Use a chave principal ou uma chave com permissão de UPLOAD habilitada.
# Se o secret começar com "-", coloque entre aspas.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

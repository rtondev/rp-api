# /etc/nginx/sites-available/api.rotapotiguar.com
# ln -s .../api.rotapotiguar.com /etc/nginx/sites-enabled/
#
# API escuta em 127.0.0.1:6000 (docker-compose.prod.yml)

server {
    listen 80;
    listen [::]:80;
    server_name api.rotapotiguar.com;

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.rotapotiguar.com;

    # certbot --nginx -d api.rotapotiguar.com
    ssl_certificate     /etc/letsencrypt/live/api.rotapotiguar.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.rotapotiguar.com/privkey.pem;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:6000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
